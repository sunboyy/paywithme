# Pay with me — environment variables
#
# This file is COMMITTED and documents EVERY env var the app uses. Copy it to a
# local `.env` (git-ignored) and fill in real values:
#
#   cp .env.example .env
#
# Use ONLY placeholder values here — never commit real secrets.
#
# Local dev (PLAN decision #24): runs against a local Postgres and, when the
# Mailgun vars are unset/empty, logs the magic-link URL to the console instead
# of sending email. Real Neon + Mailgun credentials are supplied by the user
# for staging/production.

# ──────────────────────────────────────────────────────────────────────────────
# Database (Neon in prod / local Postgres in dev) — PLAN §3, §4
# ──────────────────────────────────────────────────────────────────────────────

# App runtime connection (read in src/lib/server/db/index.ts via $env/dynamic/private).
# PROD: Neon's POOLED connection string (PgBouncer, transaction mode).
# DEV:  a local Postgres URL (see task 1.7 for local setup).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paywithme"

# Migrations connection (read in drizzle.config.ts). drizzle-kit needs a
# DIRECT / NON-POOLED connection — pooled (PgBouncer) URLs break migrations.
# PROD: Neon's DIRECT (non-pooled) connection string.
# DEV:  same as DATABASE_URL (a single local Postgres has no pooler).
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/paywithme"

# ──────────────────────────────────────────────────────────────────────────────
# Auth — better-auth + passkey plugin (WebAuthn) — PLAN §5, §11, §12
# These back the passkey + session config wired up in Phase 2.
# rpName is the constant "Pay with me" (hard-coded in the auth config, not an
# env var).
# ──────────────────────────────────────────────────────────────────────────────

# Session-signing secret. better-auth REQUIRES a secret in production.
# Generate one with:  openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# Canonical origin / base URL of the app. Doubles as the WebAuthn `origin`
# (scheme + host + port, NO trailing path). Must be HTTPS in prod.
# DEV:  http://localhost:5173
# PROD: https://paywithme.example.com
BETTER_AUTH_URL="http://localhost:5173"

# WebAuthn Relying Party ID (rpID): the registrable domain, with NO scheme/port.
# Must be the host of BETTER_AUTH_URL (or a registrable parent of it).
# DEV:  localhost
# PROD: paywithme.example.com  (the apex / prod domain)
AUTH_RP_ID="localhost"

# Comma-separated trusted origins for better-auth (CSRF + WebAuthn).
# Per PLAN §12: the canonical origin ONLY — do NOT add ephemeral preview URLs.
# DEV:  http://localhost:5173
# PROD: https://paywithme.example.com
AUTH_TRUSTED_ORIGINS="http://localhost:5173"

# ──────────────────────────────────────────────────────────────────────────────
# Email — Mailgun HTTP API — PLAN §5.2, decision #24
#
# LOCAL DEV: leave these UNSET/empty. The email helper (task 2.3) detects that
# Mailgun is not configured and logs the magic-link URL to the console instead
# of sending — no real email, no Mailgun account needed.
#
# NEEDS-INPUT: real values below are required to send live email (staging/prod).
# ──────────────────────────────────────────────────────────────────────────────

# Mailgun private API key. Source: Mailgun dashboard → API security.
MAILGUN_API_KEY=""

# The verified sending domain configured in Mailgun (e.g. mg.paywithme.example.com).
MAILGUN_DOMAIN=""

# Mailgun API region base URL. US (default): https://api.mailgun.net
# EU: https://api.eu.mailgun.net  — must match the region your domain lives in.
MAILGUN_BASE_URL="https://api.mailgun.net"

# From address for outbound email. Must be a verified sender on MAILGUN_DOMAIN.
# e.g. "Pay with me <no-reply@mg.paywithme.example.com>"
EMAIL_FROM=""
